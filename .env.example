# Copy this file to .env for local Docker or local start.sh usage.
# Do not commit real secrets.

# Optional. Used for LLM image captioning and OCR plugin workflows.
OPENAI_API_KEY=

# Optional. Path inside the container when INSTALL_MEDIA_TOOLS=true.
EXIFTOOL_PATH=/usr/bin/exiftool

# Optional Azure identity settings.
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Optional. Set true, 1, or yes to enable installed plugins.
MARKITDOWN_ENABLE_PLUGINS=

# Container UI bind settings.
MARKITDOWN_HOST=0.0.0.0
MARKITDOWN_PORT=8765
